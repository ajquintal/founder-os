# =============================================================================
# Copy to `.env.local` (git-ignored) and fill in. NEVER commit real secrets.
# The pre-commit secret-guard (scripts/check-secrets.sh) blocks accidental leaks.
# =============================================================================

# -----------------------------------------------------------------------------
# Frontend (Vite). ONLY variables prefixed VITE_ are bundled into the browser.
# Anything VITE_* is PUBLIC by definition — never put a secret key here.
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_APP_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Supabase Edge Functions (server-side). Set these in production with:
#   supabase secrets set STRIPE_SECRET_KEY=sk_test_...
# SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY are auto-injected
# by Supabase at runtime in the cloud. You still list them here so
# `supabase functions serve` works locally.
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-keep-secret

# Stripe (TEST MODE keys only in this file). Get these from the Stripe dashboard.
STRIPE_SECRET_KEY=sk_test_your_stripe_test_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
STRIPE_PRICE_ID=price_your_test_price_id

# Absolute URL of the deployed frontend — used to build Stripe redirect URLs.
APP_URL=http://localhost:5173
